# ============================================================================
# InNovaIdeia Portal — Configuração de Ambiente
# ============================================================================
# Copie este arquivo para .env e preencha com suas credenciais

# GROQ API = sua chave  

GROQ_API_KEY= sua chave

GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama3-8b-8192
GROQ_MODEL=llama-3.3-70b-versatile

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao

# Database
DATABASE_URL=sqlite:///innova_portal.db

# Rate Limiting
CONTACT_RATE_LIMIT=5 per hour
CHAT_RATE_LIMIT=10 per minute
LOGIN_RATE_LIMIT=5 per hour
REGISTER_RATE_LIMIT=3 per hour
AI_RATE_LIMIT=10 per hour

# Limites de Entrada
MAX_NAME_LENGTH=100
MAX_CONTACT_MESSAGE_LENGTH=500
MAX_CHAT_MESSAGE_LENGTH=200
MAX_TITLE_LENGTH=150
MAX_DESCRIPTION_LENGTH=500
MAX_SUMMARY_LEADS=20
